{
  "name": "baseui-cn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "registry:build": "node scripts/build-registry.mjs",
    "registry:watch": "node scripts/watch-registry.mjs",
    "docs:markdown": "node scripts/build-doc-markdown.mjs",
    "previews:build": "node scripts/build-preview-sources.mjs",
    "previews:watch": "node scripts/watch-preview-sources.mjs",
    "build:all": "node scripts/build-registry.mjs && node scripts/build-preview-sources.mjs && node scripts/build-doc-markdown.mjs"
  },
  "devDependencies": {
    "turbo": "latest",
    "typescript": "^5.4.5",
    "prettier": "^3.3.3"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
