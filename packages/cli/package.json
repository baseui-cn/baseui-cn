{
  "name": "baseui-cn",
  "version": "1.2.0",
  "description": "Add Base UI components to your app — one command at a time.",
  "keywords": [
    "base-ui",
    "components",
    "cli",
    "tailwind",
    "react"
  ],
  "license": "MIT",
  "homepage": "https://baseui-cn.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baseui-cn/baseui-cn.git"
  },
  "bin": {
    "baseui-cn": "dist/index.js"
  },
  "files": [
    "dist",
    "registry",
    "README.md"
  ],
  "scripts": {
    "build": "node ../../scripts/build-registry.mjs && tsup",
    "dev": "tsup --watch",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "dependencies": {
    "chalk": "4.1.2",
    "commander": "^12.1.0",
    "execa": "5.1.1",
    "fs-extra": "^11.2.0",
    "ora": "5.4.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.14.9",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.2.2",
    "typescript": "^5.4.5"
  }
}
